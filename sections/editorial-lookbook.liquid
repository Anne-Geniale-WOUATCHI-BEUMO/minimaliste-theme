{%- liquid
  assign layout_class = 'editorial-lookbook--left-heavy'
  if section.settings.layout == 'right-heavy'
    assign layout_class = 'editorial-lookbook--right-heavy'
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="editorial-lookbook {{ layout_class }}">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="editorial-lookbook__header">
        {%- if section.settings.subheading != blank -%}
          <p class="editorial-lookbook__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="editorial-lookbook__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="editorial-lookbook__grid">
      <div class="editorial-lookbook__hero">
        {%- if section.settings.background_image != blank -%}
          <img
            src="{{ section.settings.background_image | image_url: width: 1200 }}"
            srcset="
              {{ section.settings.background_image | image_url: width: 600 }} 600w,
              {{ section.settings.background_image | image_url: width: 900 }} 900w,
              {{ section.settings.background_image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 749px) 100vw, 65vw"
            alt="{{ section.settings.background_image.alt | default: section.settings.heading | escape }}"
            width="{{ section.settings.background_image.width }}"
            height="{{ section.settings.background_image.height }}"
            loading="lazy"
            class="editorial-lookbook__hero-image"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-lookbook__hero-placeholder' }}
        {%- endif -%}
      </div>

      <div class="editorial-lookbook__products">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          <div class="editorial-lookbook__product-card" {{ block.shopify_attributes }}>
            {%- if product != blank -%}
              <a href="{{ product.url }}" class="editorial-lookbook__product-link">
                <div class="editorial-lookbook__product-image-wrap">
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 400 }}"
                      srcset="
                        {{ product.featured_image | image_url: width: 200 }} 200w,
                        {{ product.featured_image | image_url: width: 400 }} 400w
                      "
                      sizes="(max-width: 749px) 45vw, 200px"
                      alt="{{ product.featured_image.alt | default: product.title | escape }}"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      loading="lazy"
                      class="editorial-lookbook__product-image"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'editorial-lookbook__product-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="editorial-lookbook__product-info">
                  {%- if block.settings.custom_label != blank -%}
                    <span class="editorial-lookbook__product-label">{{ block.settings.custom_label }}</span>
                  {%- endif -%}
                  <h3 class="editorial-lookbook__product-title">{{ product.title }}</h3>
                  <p class="editorial-lookbook__product-price">{{ product.price | money }}</p>
                  <span class="editorial-lookbook__view-link">View</span>
                </div>
              </a>
            {%- else -%}
              <div class="editorial-lookbook__product-link">
                <div class="editorial-lookbook__product-image-wrap">
                  {{ 'product-1' | placeholder_svg_tag: 'editorial-lookbook__product-placeholder' }}
                </div>
                <div class="editorial-lookbook__product-info">
                  {%- if block.settings.custom_label != blank -%}
                    <span class="editorial-lookbook__product-label">{{ block.settings.custom_label }}</span>
                  {%- endif -%}
                  <h3 class="editorial-lookbook__product-title">Sample product</h3>
                  <p class="editorial-lookbook__product-price">$0.00</p>
                  <span class="editorial-lookbook__view-link">View</span>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-lookbook {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .editorial-lookbook__header {
    margin-bottom: 40px;
  }

  .editorial-lookbook__subheading {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 8px;
  }

  .editorial-lookbook__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0;
    line-height: 1.15;
  }

  /* Grid layout */
  .editorial-lookbook__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .editorial-lookbook__grid {
      gap: 32px;
    }

    .editorial-lookbook--left-heavy .editorial-lookbook__grid {
      grid-template-columns: 65fr 35fr;
    }

    .editorial-lookbook--right-heavy .editorial-lookbook__grid {
      grid-template-columns: 35fr 65fr;
    }

    .editorial-lookbook--right-heavy .editorial-lookbook__hero {
      order: 2;
    }

    .editorial-lookbook--right-heavy .editorial-lookbook__products {
      order: 1;
    }
  }

  /* Hero image */
  .editorial-lookbook__hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius, 4px);
  }

  .editorial-lookbook__hero-image,
  .editorial-lookbook__hero-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 320px;
  }

  @media screen and (min-width: 750px) {
    .editorial-lookbook__hero-image,
    .editorial-lookbook__hero-placeholder {
      min-height: 500px;
    }
  }

  /* Products grid */
  .editorial-lookbook__products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-content: start;
  }

  @media screen and (min-width: 750px) {
    .editorial-lookbook__products {
      gap: 20px;
      align-content: stretch;
    }
  }

  /* Product card */
  .editorial-lookbook__product-card {
    position: relative;
  }

  .editorial-lookbook__product-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    border-radius: var(--style-border-radius, 4px);
    transition: border-color 0.25s ease;
    overflow: hidden;
  }

  .editorial-lookbook__product-link:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.2);
  }

  /* Product image */
  .editorial-lookbook__product-image-wrap {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.03);
  }

  .editorial-lookbook__product-image,
  .editorial-lookbook__product-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  /* Product info */
  .editorial-lookbook__product-info {
    padding: 12px;
  }

  .editorial-lookbook__product-label {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 4px;
  }

  .editorial-lookbook__product-title {
    font-size: 0.875rem;
    font-weight: 500;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .editorial-lookbook__product-price {
    font-size: 0.8125rem;
    margin: 0 0 8px;
    opacity: 0.7;
  }

  .editorial-lookbook__view-link {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.6;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 0.2s ease;
  }

  .editorial-lookbook__product-link:hover .editorial-lookbook__view-link {
    opacity: 1;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .editorial-lookbook__hero-image,
    .editorial-lookbook__hero-placeholder {
      aspect-ratio: 4 / 3;
      min-height: auto;
    }

    .editorial-lookbook__product-info {
      padding: 8px;
    }

    .editorial-lookbook__product-title {
      font-size: 0.8125rem;
    }

    .editorial-lookbook__product-price {
      font-size: 0.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial lookbook",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Custom label",
          "info": "Optional label shown above the product title (e.g. \"New\", \"Best Seller\")"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated editorial"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "left-heavy",
          "label": "Image left (60/40)"
        },
        {
          "value": "right-heavy",
          "label": "Image right (40/60)"
        }
      ],
      "default": "left-heavy"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Editorial lookbook",
      "category": "Premium",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "custom_label": "Best Seller"
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_label": "New"
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_label": ""
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_label": "Limited"
          }
        }
      ]
    }
  ]
}
{% endschema %}
