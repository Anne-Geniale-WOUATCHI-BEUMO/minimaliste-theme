<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --timeline-line-color: {{ section.settings.line_color }};
  "
>
  <div class="brand-timeline">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="brand-timeline__header">
        {%- if section.settings.subheading != blank -%}
          <p class="brand-timeline__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="brand-timeline__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="brand-timeline__track">
        <div class="brand-timeline__line" aria-hidden="true"></div>

        {%- for block in section.blocks -%}
          {%- assign is_even = forloop.index | modulo: 2 -%}
          <div
            class="brand-timeline__item {% if is_even == 0 %}brand-timeline__item--even{% else %}brand-timeline__item--odd{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="brand-timeline__dot" aria-hidden="true"></div>

            <div class="brand-timeline__content">
              {%- if block.settings.image != blank -%}
                <div class="brand-timeline__image-wrap">
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 300 }} 300w,
                      {{ block.settings.image | image_url: width: 600 }} 600w
                    "
                    sizes="(max-width: 749px) 100vw, 280px"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    loading="lazy"
                    class="brand-timeline__image"
                  >
                </div>
              {%- endif -%}

              <div class="brand-timeline__text">
                {%- if block.settings.year != blank -%}
                  <span class="brand-timeline__year">{{ block.settings.year }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="brand-timeline__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <div class="brand-timeline__description">{{ block.settings.description }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .brand-timeline {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .brand-timeline__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .brand-timeline__subheading {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 8px;
  }

  .brand-timeline__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0;
    line-height: 1.15;
  }

  /* Timeline track */
  .brand-timeline__track {
    position: relative;
    padding-top: 8px;
  }

  /* Central vertical line */
  .brand-timeline__line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--timeline-line-color, rgb(var(--color-foreground-rgb, 0 0 0) / 0.15));
    left: 20px;
  }

  @media screen and (min-width: 750px) {
    .brand-timeline__line {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  /* Timeline item */
  .brand-timeline__item {
    position: relative;
    padding-bottom: 48px;
    padding-left: 52px;
  }

  .brand-timeline__item:last-child {
    padding-bottom: 0;
  }

  /* Dot marker */
  .brand-timeline__dot {
    position: absolute;
    left: 14px;
    top: 6px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid var(--timeline-line-color, rgb(var(--color-foreground-rgb, 0 0 0) / 0.15));
    background: rgb(var(--color-background-rgb, 255 255 255));
    z-index: 1;
  }

  /* Content card */
  .brand-timeline__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Image */
  .brand-timeline__image-wrap {
    overflow: hidden;
    border-radius: var(--style-border-radius, 4px);
  }

  .brand-timeline__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  /* Text content */
  .brand-timeline__year {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 4px;
    font-weight: 600;
  }

  .brand-timeline__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .brand-timeline__description {
    font-size: 0.9375rem;
    line-height: 1.65;
    opacity: 0.75;
  }

  .brand-timeline__description p {
    margin: 0 0 8px;
  }

  .brand-timeline__description p:last-child {
    margin-bottom: 0;
  }

  /* Desktop: alternating layout */
  @media screen and (min-width: 750px) {
    .brand-timeline__item {
      width: 50%;
      padding-bottom: 56px;
      padding-left: 0;
    }

    .brand-timeline__dot {
      width: 15px;
      height: 15px;
    }

    /* Odd items: content on the left, dot at center-right */
    .brand-timeline__item--odd {
      margin-left: 0;
      padding-right: 48px;
      text-align: right;
    }

    .brand-timeline__item--odd .brand-timeline__dot {
      left: auto;
      right: -8px;
    }

    .brand-timeline__item--odd .brand-timeline__content {
      align-items: flex-end;
    }

    .brand-timeline__item--odd .brand-timeline__image-wrap {
      max-width: 320px;
    }

    /* Even items: content on the right, dot at center-left */
    .brand-timeline__item--even {
      margin-left: 50%;
      padding-left: 48px;
      text-align: left;
    }

    .brand-timeline__item--even .brand-timeline__dot {
      left: -8px;
    }

    .brand-timeline__item--even .brand-timeline__content {
      align-items: flex-start;
    }

    .brand-timeline__item--even .brand-timeline__image-wrap {
      max-width: 320px;
    }
  }

  /* Mobile: single column with line on the left */
  @media screen and (max-width: 749px) {
    .brand-timeline__header {
      margin-bottom: 40px;
    }

    .brand-timeline__item {
      padding-bottom: 36px;
    }

    .brand-timeline__image-wrap {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand story timeline",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2020"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our beginning"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Share a milestone from your brand journey. Tell customers about the values that drive your business.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A journey of craft and passion"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Timeline line color",
      "default": "#a855f7"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Brand story timeline",
      "category": "Premium",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "year": "2018",
            "title": "The spark",
            "description": "<p>It all started with a simple idea: create products that are both beautiful and sustainable. We set out to prove that great design and responsible sourcing can coexist.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2019",
            "title": "First collection",
            "description": "<p>After months of research and development, we launched our first collection. The response was overwhelming and confirmed we were on the right path.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2021",
            "title": "Going global",
            "description": "<p>We expanded to international markets, bringing our carefully crafted products to customers in over 30 countries worldwide.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "Looking ahead",
            "description": "<p>With a growing community and an expanding product line, we continue to push the boundaries of sustainable design and ethical manufacturing.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
