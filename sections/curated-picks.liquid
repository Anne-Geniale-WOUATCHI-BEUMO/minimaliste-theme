{%- assign featured = section.settings.featured_product -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="curated-picks">
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="curated-picks__header">
        {%- if section.settings.subtitle != blank -%}
          <p class="curated-picks__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="curated-picks__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="curated-picks__layout">
      <!-- Featured product (large card) -->
      <div class="curated-picks__featured">
        {%- if featured != blank -%}
          <a href="{{ featured.url }}" class="curated-picks__featured-link">
            <div class="curated-picks__featured-image-wrap">
              {%- if featured.featured_image != blank -%}
                <img
                  src="{{ featured.featured_image | image_url: width: 800 }}"
                  srcset="
                    {{ featured.featured_image | image_url: width: 400 }} 400w,
                    {{ featured.featured_image | image_url: width: 600 }} 600w,
                    {{ featured.featured_image | image_url: width: 800 }} 800w
                  "
                  sizes="(max-width: 749px) 100vw, 50vw"
                  alt="{{ featured.featured_image.alt | default: featured.title | escape }}"
                  width="{{ featured.featured_image.width }}"
                  height="{{ featured.featured_image.height }}"
                  loading="lazy"
                  class="curated-picks__featured-image"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'curated-picks__featured-placeholder' }}
              {%- endif -%}
            </div>
            <div class="curated-picks__featured-info">
              <span class="curated-picks__featured-badge">Featured</span>
              <h3 class="curated-picks__featured-title">{{ featured.title }}</h3>
              <p class="curated-picks__featured-price">{{ featured.price | money }}</p>
              {%- if featured.description != blank -%}
                <div class="curated-picks__featured-description">
                  {{ featured.description | strip_html | truncate: 160 }}
                </div>
              {%- endif -%}
              <span class="curated-picks__featured-cta">Shop now</span>
            </div>
          </a>
        {%- else -%}
          <div class="curated-picks__featured-link">
            <div class="curated-picks__featured-image-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'curated-picks__featured-placeholder' }}
            </div>
            <div class="curated-picks__featured-info">
              <span class="curated-picks__featured-badge">Featured</span>
              <h3 class="curated-picks__featured-title">Featured product</h3>
              <p class="curated-picks__featured-price">$0.00</p>
              <div class="curated-picks__featured-description">
                Add a featured product to highlight your top pick. This large card draws attention to your most important item.
              </div>
              <span class="curated-picks__featured-cta">Shop now</span>
            </div>
          </div>
        {%- endif -%}
      </div>

      <!-- Supporting products + editorial note -->
      <div class="curated-picks__sidebar">
        {%- if section.settings.editorial_note != blank -%}
          <div class="curated-picks__editorial-note">
            <div class="curated-picks__editorial-bar" aria-hidden="true"></div>
            <div class="curated-picks__editorial-text">
              {{ section.settings.editorial_note }}
            </div>
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="curated-picks__supporting-grid">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              <div class="curated-picks__supporting-card" {{ block.shopify_attributes }}>
                {%- if product != blank -%}
                  <a href="{{ product.url }}" class="curated-picks__supporting-link">
                    <div class="curated-picks__supporting-image-wrap">
                      {%- if product.featured_image != blank -%}
                        <img
                          src="{{ product.featured_image | image_url: width: 400 }}"
                          srcset="
                            {{ product.featured_image | image_url: width: 200 }} 200w,
                            {{ product.featured_image | image_url: width: 400 }} 400w
                          "
                          sizes="(max-width: 749px) 45vw, 200px"
                          alt="{{ product.featured_image.alt | default: product.title | escape }}"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          loading="lazy"
                          class="curated-picks__supporting-image"
                        >
                      {%- else -%}
                        {{ 'product-2' | placeholder_svg_tag: 'curated-picks__supporting-placeholder' }}
                      {%- endif -%}
                    </div>
                    <div class="curated-picks__supporting-info">
                      <h4 class="curated-picks__supporting-title">{{ product.title }}</h4>
                      <p class="curated-picks__supporting-price">{{ product.price | money }}</p>
                    </div>
                  </a>
                {%- else -%}
                  <div class="curated-picks__supporting-link">
                    <div class="curated-picks__supporting-image-wrap">
                      {{ 'product-2' | placeholder_svg_tag: 'curated-picks__supporting-placeholder' }}
                    </div>
                    <div class="curated-picks__supporting-info">
                      <h4 class="curated-picks__supporting-title">Sample product</h4>
                      <p class="curated-picks__supporting-price">$0.00</p>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .curated-picks {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .curated-picks__header {
    margin-bottom: 40px;
  }

  .curated-picks__subtitle {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 8px;
  }

  .curated-picks__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0;
    line-height: 1.15;
  }

  /* Main layout */
  .curated-picks__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 750px) {
    .curated-picks__layout {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
    }
  }

  /* Featured card */
  .curated-picks__featured {
    position: relative;
  }

  .curated-picks__featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--style-border-radius, 4px);
    overflow: hidden;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.06);
    transition: border-color 0.25s ease;
  }

  .curated-picks__featured-link:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.15);
  }

  .curated-picks__featured-image-wrap {
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.03);
  }

  .curated-picks__featured-image,
  .curated-picks__featured-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .curated-picks__featured-info {
    padding: 24px;
  }

  .curated-picks__featured-badge {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .curated-picks__featured-title {
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.25;
  }

  .curated-picks__featured-price {
    font-size: 1rem;
    margin: 0 0 12px;
    opacity: 0.7;
  }

  .curated-picks__featured-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.65;
    margin-bottom: 20px;
  }

  .curated-picks__featured-cta {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 1.5px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.2s ease;
  }

  .curated-picks__featured-link:hover .curated-picks__featured-cta {
    opacity: 0.7;
  }

  /* Sidebar */
  .curated-picks__sidebar {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Editorial note */
  .curated-picks__editorial-note {
    display: flex;
    gap: 16px;
    align-items: stretch;
  }

  .curated-picks__editorial-bar {
    width: 2px;
    flex-shrink: 0;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.12);
    border-radius: 1px;
  }

  .curated-picks__editorial-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    font-style: italic;
    opacity: 0.7;
    padding: 4px 0;
  }

  .curated-picks__editorial-text p {
    margin: 0 0 8px;
  }

  .curated-picks__editorial-text p:last-child {
    margin-bottom: 0;
  }

  /* Supporting grid */
  .curated-picks__supporting-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* Supporting card */
  .curated-picks__supporting-card {
    position: relative;
  }

  .curated-picks__supporting-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--style-border-radius, 4px);
    overflow: hidden;
    border: 1px solid transparent;
    transition: border-color 0.25s ease;
  }

  .curated-picks__supporting-link:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.15);
  }

  .curated-picks__supporting-image-wrap {
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.03);
  }

  .curated-picks__supporting-image,
  .curated-picks__supporting-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .curated-picks__supporting-info {
    padding: 10px 12px;
  }

  .curated-picks__supporting-title {
    font-size: 0.8125rem;
    font-weight: 500;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .curated-picks__supporting-price {
    font-size: 0.75rem;
    margin: 0;
    opacity: 0.65;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .curated-picks__featured-info {
      padding: 16px;
    }

    .curated-picks__featured-title {
      font-size: 1.125rem;
    }

    .curated-picks__featured-description {
      font-size: 0.875rem;
      margin-bottom: 16px;
    }

    .curated-picks__supporting-grid {
      gap: 12px;
    }

    .curated-picks__supporting-info {
      padding: 8px 10px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Curated picks",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "supporting_product",
      "name": "Supporting product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Editor's Choice"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Curated picks"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "richtext",
      "id": "editorial_note",
      "label": "Editorial note",
      "default": "<p>Each piece in this collection has been hand-selected by our editors for its exceptional craftsmanship, timeless design, and lasting quality.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Curated picks",
      "category": "Premium",
      "settings": {
        "editorial_note": "<p>Each piece in this collection has been hand-selected by our editors for its exceptional craftsmanship, timeless design, and lasting quality.</p>"
      },
      "blocks": [
        {
          "type": "supporting_product"
        },
        {
          "type": "supporting_product"
        },
        {
          "type": "supporting_product"
        },
        {
          "type": "supporting_product"
        }
      ]
    }
  ]
}
{% endschema %}
