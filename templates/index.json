    "brand_story_timeline_1": {
      "type": "brand-story-timeline",
      "settings": {
        "heading": "Our Story",
        "subheading": "A journey of intention and craft",
        "line_color": "#8c7b6b",
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": {
        "milestone_1": {
          "type": "milestone",
          "settings": {
            "year": "2017",
            "title": "A quiet beginning",
            "description": "<p>What started as a personal search for honest, well-made home goods became something more. Unable to find objects that felt both beautiful and purposeful, we began sourcing directly from small workshops in Copenhagen and Kyoto.</p>"
          }
        },
        "milestone_2": {
          "type": "milestone",
          "settings": {
            "year": "2019",
            "title": "First collection",
            "description": "<p>Our debut collection of hand-thrown ceramics and linen textiles launched online. Every piece sold out within three weeks, confirming what we had always believed: people are ready for less, but better.</p>"
          }
        },
        "milestone_3": {
          "type": "milestone",
          "settings": {
            "year": "2021",
            "title": "The workshop program",
            "description": "<p>We launched our Maker Residency, inviting independent craftspeople to collaborate on limited-edition pieces. The program now supports 12 artisan studios across three continents.</p>"
          }
        },
        "milestone_4": {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "Growing with purpose",
            "description": "<p>With a community of over 50,000 customers in 28 countries, we remain committed to small-batch production, natural materials, and the belief that thoughtful design can make daily life more meaningful.</p>"
          }
        }
      },
      "block_order": ["milestone_1", "milestone_2", "milestone_3", "milestone_4"]
    },
